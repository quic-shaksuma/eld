# Note: PT_ARM_EXIDX is defined as (PT_LOPROC + 1) in elf.h — a computed
# value — so gen_elf_keywords.py correctly excludes it from eldKwSegType.
# Line 151 ("  p_exidx   PT_ARM_EXIDX") therefore has no syntax group.
#
# eldKwSegType: all PT_* segment type names used in PHDRS blocks.
# Note: these lines have no trailing ';' so eldExprLine does not capture them,
# allowing eldKwSegType to fire.
#
# Line 140: "  p_null    PT_NULL"
#   140:13 = 'P' → eldKwSegType  (start of PT_NULL)
#   140:19 = 'L' → eldKwSegType  (last char of PT_NULL)
#
# Line 141: "  p_load    PT_LOAD"
#   141:13 = 'P' → eldKwSegType  (start of PT_LOAD)
#   141:19 = 'D' → eldKwSegType  (last char of PT_LOAD)
#
# Line 142: "  p_dyn     PT_DYNAMIC"
#   142:13 = 'P' → eldKwSegType  (start of PT_DYNAMIC)
#   142:22 = 'C' → eldKwSegType  (last char of PT_DYNAMIC)
#
# Line 143: "  p_interp  PT_INTERP"
#   143:13 = 'P' → eldKwSegType  (start of PT_INTERP)
#   143:21 = 'P' → eldKwSegType  (last char of PT_INTERP)
#
# Line 144: "  p_note    PT_NOTE"
#   144:13 = 'P' → eldKwSegType  (start of PT_NOTE)
#   144:19 = 'E' → eldKwSegType  (last char of PT_NOTE)
#
# Line 145: "  p_shlib   PT_SHLIB"
#   145:13 = 'P' → eldKwSegType  (start of PT_SHLIB)
#   145:20 = 'B' → eldKwSegType  (last char of PT_SHLIB)
#
# Line 146: "  p_phdr    PT_PHDR"
#   146:13 = 'P' → eldKwSegType  (start of PT_PHDR)
#   146:19 = 'R' → eldKwSegType  (last char of PT_PHDR)
#
# Line 147: "  p_tls     PT_TLS"
#   147:13 = 'P' → eldKwSegType  (start of PT_TLS)
#   147:18 = 'S' → eldKwSegType  (last char of PT_TLS)
#
# Line 148: "  p_eh      PT_GNU_EH_FRAME"
