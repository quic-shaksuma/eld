# RUN: %check_syn --syntax %eld_vim --input %inputs/sample.map \
# RUN:   --check 2:1:eldMetaKey \
# RUN:   --check 2:3:eldMetaKey \
# RUN:   --check 2:13:eldMetaKey \
# RUN:   --check 2:14:eldMetaKey \
# RUN:   --check 2:15:eldMetaKey \
# RUN:   --check 2:16:eldComment \
# RUN:   --check 2:17:eldComment
#
# Line 2: "# CommandLine : ld.eld -T script.t -o output.elf foo.o bar.o"
# The "# CommandLine :" prefix is a metadata key (eldMetaKey).
# Everything after the ':' is still a comment (eldComment).
#
#   2:1  = '#'  → eldMetaKey  (start of key pattern)
#   2:3  = 'C'  → eldMetaKey  (key body)
#   2:13 = 'e'  → eldMetaKey  (last char of "CommandLine")
#   2:14 = ' '  → eldMetaKey  (space before colon)
#   2:15 = ':'  → eldMetaKey  (the colon itself, end of key match)
#   2:16 = ' '  → eldComment  (space after colon, back to comment)
#   2:17 = 'l'  → eldComment  (body of command-line value)
