# RUN: %check_syn --syntax %eld_vim --input %inputs/sample.ld \
# RUN:   --check 1:1:eldLsComment \
# RUN:   --check 1:3:eldLsComment \
# RUN:   --check 1:54:eldLsComment \
# RUN:   --check 1:55:eldLsComment
#
# Line 1 of sample.ld: "/* ELD linker script for testing syntax highlighting */"
# Block comments (/* ... */) in linker scripts use eldLsComment.
#   1:1  = '/'  → eldLsComment  (opening '/')
#   1:3  = 'E'  → eldLsComment  (body)
#   1:54 = '*'  → eldLsComment  (closing '*')
#   1:55 = '/'  → eldLsComment  (closing '/')
