# lit site configuration generated by CMake.
# Sets test_exec_root to the CMake build directory so that test output
# (e.g. Output/) is written there rather than in the source tree.

@LIT_SITE_CFG_IN_HEADER@

config.vim_test_source_root = "@ELD_VIM_TEST_SOURCE_DIR@"
config.vim_test_exec_root   = "@ELD_VIM_TEST_EXEC_DIR@"
config.vim_binary           = "@ELD_VIM_BINARY@"
config.python_executable    = "@PYTHON_EXECUTABLE@"

# Let the main config do the real work.
lit_config.load_config(config, "@ELD_VIM_TEST_SOURCE_DIR@/lit.cfg")
