# RUN:   --check 28:14:eldKwAssign \
# RUN:   --check 28:15:eldExprParen \
# RUN:   --check 28:16:eldExprLHS \
# RUN:   --check 28:22:eldExprLHS \
# RUN:   --check 28:23:eldExprEval \
# RUN:   --check 28:27:eldExprEval \
# RUN:   --check 28:29:eldExprOp \
# RUN:   --check 28:31:eldExprDot \
# RUN:   --check 28:32:eldExprEval \
# RUN:   --check 28:36:eldExprEval \
# RUN:   --check 28:37:eldExprParen \
