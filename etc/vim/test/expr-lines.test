# RUN:   --check 29:34:eldExprParen \
# RUN:   --check 29:35:eldExprLine \
# RUN:   --check 29:37:eldExprComment
#
# Map-file expression lines with ELD-injected evaluated values.
#
# Line 28: "PROVIDE_HIDDEN(__start(0x0) = .(0x0)); # PROVIDE_HIDDEN(...); script.t"
#   28:1  = 'P' → eldKwAssign    (start of PROVIDE_HIDDEN)
#   28:14 = 'N' → eldKwAssign    (last char of PROVIDE_HIDDEN)
#   28:15 = '(' → eldExprParen   (outer open paren)
#   28:16 = '_' → eldExprLHS     (start of __start)
#   28:22 = 't' → eldExprLHS     (last char of __start)
#   28:23 = '(' → eldExprEval    (start of (0x0) eval)
#   28:27 = ')' → eldExprEval    (end of (0x0) eval)
#   28:29 = '=' → eldExprOp      (assignment operator)
#   28:31 = '.' → eldExprDot     (location counter)
#   28:32 = '(' → eldExprEval    (start of .(0x0) eval)
#   28:36 = ')' → eldExprEval    (end of .(0x0) eval)
#   28:37 = ')' → eldExprParen   (outer close paren)
#   28:38 = ';' → eldExprLine    (semicolon)
#   28:40 = '#' → eldExprComment (start of trailing comment)
#   28:78 = 't' → eldExprComment (last char of "script.t")
#
# Line 29: ".(0x1000) = ALIGN(.(0x1c), 0x1000); # . = ALIGN(., 0x1000); script.t"
#   29:1  = '.' → eldExprDot     (location counter at line start)
#   29:2  = '(' → eldExprEval    (start of (0x1000) eval)
#   29:9  = ')' → eldExprEval    (end of (0x1000) eval)
#   29:11 = '=' → eldExprOp      (assignment operator)
#   29:13 = 'A' → eldKwExpr      (start of ALIGN)
#   29:17 = 'N' → eldKwExpr      (last char of ALIGN)
#   29:18 = '(' → eldExprParen   (open paren of ALIGN call)
#   29:19 = '.' → eldExprDot     (location counter argument)
#   29:20 = '(' → eldExprEval    (start of .(0x1c) eval)
#   29:25 = ')' → eldExprEval    (end of .(0x1c) eval)
#   29:28 = '0' → eldHex         (start of 0x1000)
#   29:33 = '0' → eldHex         (last char of 0x1000)
#   29:34 = ')' → eldExprParen   (close paren of ALIGN call)
#   29:35 = ';' → eldExprLine    (semicolon)
#   29:37 = '#' → eldExprComment (start of trailing comment)
