#   67:26 = 'R' → eldKwTopLevel  (last char of PLUGIN_OUTPUT_SECTION_ITER)
#
# Line 68: "PLUGIN_SECTION_MATCHER(match_fn)"
#   68:1  = 'P' → eldKwTopLevel  (start of PLUGIN_SECTION_MATCHER)
#   68:22 = 'R' → eldKwTopLevel  (last char of PLUGIN_SECTION_MATCHER)
#
# Line 69: "INCLUDE_OPTIONAL maybe.ld"
#   69:1  = 'I' → eldKwTopLevel  (start of INCLUDE_OPTIONAL)
