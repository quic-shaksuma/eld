#UNSUPPORTED: windows
#---RepeatedIncludes.test--------------------- Executable,LS------------------#
#BEGIN_COMMENT
This test checks that the repeated INCLUDEs in linker script does not lead to
include cycle error.
#END_COMMENT
RUN: %touch %t1.1.o
RUN: %touch 1.t
RUN: %mkdir %t1.scripts
RUN: %touch %t1.scripts/2.t
RUN: %link %emulation %linkopts %t1.1.o -T %p/Inputs/script.t -L %t1.scripts -o %t1.1.out
