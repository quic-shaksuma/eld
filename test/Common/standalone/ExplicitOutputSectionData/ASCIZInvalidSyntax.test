#---ASCIZInvalidSyntax.test--------------------- Executable---------------------#
#BEGIN_COMMENT
# This test checks that ASCIZ requires a quoted string literal.
#END_COMMENT
RUN: %clang %clangopts -o %t1.o -c %p/Inputs/1.c
RUN: %not %link %linkopts -o %t1.elf %t1.o -T %p/Inputs/asciiz-invalid-unquoted.t 2>&1 | %filecheck %s

CHECK: Error: {{.*}}asciiz-invalid-unquoted.t:4: ASCIZ expects a quoted string literal
