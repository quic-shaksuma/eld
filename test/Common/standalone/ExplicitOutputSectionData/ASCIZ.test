#---ASCIZ.test--------------------- Executable---------------------#
#BEGIN_COMMENT
# This test checks the behavior of the ASCIZ linker script command, which emits
# a null-terminated ASCII string into an output section.
# ASCIZ ("hello") emits: 68 65 6c 6c 6f 00
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -o %t1.o -c %p/Inputs/1.c
RUN: %link -MapStyle txt %linkopts -o %t1.elf %t1.o -T %p/Inputs/asciiz.t -Map %t1.map.txt
RUN: %readelf -S %t1.elf 2>&1 | %filecheck %s --check-prefix=SECTIONS
RUN: %objdump -s %t1.elf --section .rodata | %filecheck %s --check-prefix=RODATA
RUN: %filecheck %s --check-prefix=MAP < %t1.map.txt
#END_TEST
SECTIONS: .rodata PROGBITS {{.*}} {{0+c}} {{.*}} A
RODATA: {{[0-9a-f]+}} 68656c6c 6f00{{.*}}
MAP-COUNT-2: ASCIZ
