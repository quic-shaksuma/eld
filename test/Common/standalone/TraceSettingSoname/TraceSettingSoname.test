#---TraceDynamicLinkingSoname.test------------- Executable ------------------#
#BEGIN_COMMENT
# Test that --trace=dynamic-linking emits a trace message when setting soname.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/1.c -o %t1.o -fPIC
RUN: %link %linkopts -o %t1.so -shared %t1.o -soname libfoo.so.1 --trace=dynamic-linking 2>&1 | %filecheck %s
#END_TEST
CHECK: Trace: Setting 'libfoo.so.1' as the soname
