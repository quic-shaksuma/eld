#---ReferencedSymbolsMember.test---Executable --------------------#
#BEGIN_COMMENT
# Verify helper mode prints referenced symbols grouped by archive member.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %ar -cr %tlib.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlib.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --referenced-symbols-member "*foo*.o" 2>&1 | %filecheck %s --check-prefix=REFMEM
#END_TEST

REFMEM: Referenced symbols for member pattern: *foo*.o
REFMEM: unique members: 1
REFMEM: Member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
REFMEM: symbol: bar
