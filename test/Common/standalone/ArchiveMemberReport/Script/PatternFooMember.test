#---PatternFooMember.test---Executable --------------------#
#BEGIN_COMMENT
# Verify script output for member path glob pattern.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %ar -cr %tlib.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlib.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --pattern "*foo.o" 2>&1 | %filecheck %s --check-prefix=PATFOO
#END_TEST

PATFOO: Trace for pattern: *foo.o
PATFOO: unique members: 1
PATFOO: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
PATFOO: symbol: foo
