#---PatternAllMembers.test---Executable --------------------#
#BEGIN_COMMENT
# Verify script output when pattern matches multiple members.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %ar -cr %tlib.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlib.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --pattern "*lib.a(*" 2>&1 | %filecheck %s --check-prefix=ALL
#END_TEST

ALL: Trace for pattern: *lib.a(*
ALL: unique members: 2
ALL-DAG: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
ALL-DAG: member: {{.*\.a\([^)]*bar[^)]*\.o\)}}
