#---SymbolExact.test---Executable --------------------#
#BEGIN_COMMENT
# Verify script output for exact symbol match.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %ar -cr %tlib.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlib.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --symbol foo 2>&1 | %filecheck %s --check-prefix=FOO
#END_TEST

FOO: Trace for symbol: foo
FOO: unique members: 1
FOO: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
FOO: Trace 1
FOO: referrer: {{.*}}main.o
FOO: symbol: foo
FOO: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
