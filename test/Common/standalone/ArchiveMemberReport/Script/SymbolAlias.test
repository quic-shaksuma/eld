#---SymbolAlias.test---Executable --------------------#
#BEGIN_COMMENT
# Verify script output for alias symbol match.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %ar -cr %tlib.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlib.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --symbol foo_alias 2>&1 | %filecheck %s --check-prefix=ALIAS
#END_TEST

ALIAS: Trace for symbol: foo_alias
ALIAS: unique members: 1
ALIAS: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
ALIAS: symbol: foo
