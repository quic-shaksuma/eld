#---SymbolExactThinArchive.test---Executable --------------------#
#BEGIN_COMMENT
# Verify trace script can follow pull-in chains for a thin archive report.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/../Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/../Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/../Inputs/bar.c -o %t.bar.o
RUN: %ar -crT %tlibthin.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlibthin.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --symbol foo 2>&1 | %filecheck %s --check-prefix=THINSYM
#END_TEST

THINSYM: Trace for symbol: foo
THINSYM: unique members: 1
THINSYM: member: {{.*libthin\.a\([^)]*foo[^)]*\.o\)}}
THINSYM: Trace 1
THINSYM: referrer: {{.*}}main.o
THINSYM: symbol: foo
