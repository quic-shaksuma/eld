#---SymbolWhyNeeded.test---Executable --------------------#
#BEGIN_COMMENT
# Verify --why-needed matches only pull-in symbols and explains who requested it.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %ar -cr %tlib.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlib.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --symbol foo --why-needed 2>&1 | %filecheck %s --check-prefix=WHY
#END_TEST

WHY: Why symbol needed: foo
WHY: unique members: 1
WHY: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
WHY: why-symbol: foo
WHY: requested-by: {{.*}}main.o
WHY: symbol: foo

RUN: %python %xarchmemtrace %t.report.json --symbol bar --why-needed 2>&1 | %filecheck %s --check-prefix=REF

REF: Why symbol needed: bar
REF: unique members: 2
REF-DAG: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
REF-DAG: member: {{.*\.a\([^)]*bar[^)]*\.o\)}}
REF-DAG: member-references: bar
REF-DAG: because: {{.*\.a\([^)]*foo[^)]*\.o\)}} references bar
REF-DAG: chain: {{.*}}main.o --foo--> {{.*\.a\([^)]*foo[^)]*\.o\)}} | {{.*\.a\([^)]*foo[^)]*\.o\)}} --bar--> {{.*\.a\([^)]*bar[^)]*\.o\)}}
