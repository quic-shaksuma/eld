#---SymbolGlobBar.test---Executable --------------------#
#BEGIN_COMMENT
# Verify script output for glob symbol match.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/main.c -o %t.main.o
RUN: %clang %clangopts -c %p/Inputs/foo.c -o %t.foo.o
RUN: %clang %clangopts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %ar -cr %tlib.a %t.foo.o %t.bar.o
RUN: %link %linkopts -o %t.out %t.main.o %tlib.a --archive-member-report %t.report.json
RUN: %python %xarchmemtrace %t.report.json --symbol "*bar" 2>&1 | %filecheck %s --check-prefix=BAR
#END_TEST

BAR: Trace for symbol: *bar
BAR: unique members: 2
BAR-DAG: member: {{.*\.a\([^)]*foo[^)]*\.o\)}}
BAR-DAG: member: {{.*\.a\([^)]*bar[^)]*\.o\)}}
BAR-DAG: symbol: bar
