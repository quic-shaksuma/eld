#---EmitRelocsAggregation.test--------------------------- Executable --------------------#
#BEGIN_COMMENT
# This checks that --emit-relocs creates a single relocation section for the
# linker-script output text section and does not create per-input text
# relocation sections.
#END_COMMENT
#START_TEST
RUN: %clang %clangg0opts -c %p/Inputs/test.c -o %t.test.o
RUN: %clang %clangg0opts -c %p/Inputs/bar.c -o %t.bar.o
RUN: %link %linkopts %t.test.o %t.bar.o -T %p/Inputs/script.t --emit-relocs -o %t.out

RUN: %readelf -r %t.out | %filecheck %s --check-prefix=RELOCS
RUN: %readelf -W -S %t.out | %filecheck %s --check-prefix=SECTIONS

RELOCS-NOT: Relocation section '.rel{{a?}}\.text'
RELOCS-NOT: Relocation section '.rel{{a?}}mycode_1'
RELOCS-NOT: Relocation section '.rel{{a?}}mycode_2'
RELOCS: Relocation section '.rel{{a?}}CODE' at offset
RELOCS-NOT: Relocation section '.rel{{a?}}CODE'

SECTIONS-LABEL: Section Headers:
SECTIONS-NOT: .rel{{a?}}\.text
SECTIONS-NOT: .rel{{a?}}mycode_1
SECTIONS-NOT: .rel{{a?}}mycode_2
SECTIONS: .rel{{a?}}CODE
SECTIONS-NOT: .rel{{a?}}CODE
#END_TEST
