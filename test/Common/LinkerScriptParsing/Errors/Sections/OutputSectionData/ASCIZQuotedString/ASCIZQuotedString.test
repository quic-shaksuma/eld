UNSUPPORTED: old_lsparser
#---ASCIZQuotedString.test--------------------- Executable------------------#
#BEGIN_COMMENT
# This test checks that ASCIZ accepts only a quoted string literal.
#END_COMMENT
RUN: %not %lsparserverifier %lsparserverifier_opts %p/Inputs/script.t 2>&1 | %filecheck %s

CHECK: Error: {{.*}}script.t:3: ASCIZ expects a quoted string literal
