## Link with Xqci enabled, GP relaxation disabled. With GP = 0x10000000,
## all GP-relative symbols exceed the Abs-xqci range too, so they cannot
## relax via any path. Only the explicitly small absolute symbols relax.
RUN: %link %linkopts --relax-xqci --no-relax-gp -MapStyle txt -Map %t.2.map --verbose %t.o -o %t.2.out -T %p/Inputs/1.t 2>&1 | %filecheck %s --check-prefix=VERBOSE-NO-GP

