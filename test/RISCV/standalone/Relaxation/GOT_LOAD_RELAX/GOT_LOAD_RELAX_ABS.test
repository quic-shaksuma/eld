SHARED-DUMP-NEXT: {{l[wd]}} a0, {{-?[0-9]+}}(a0)
SHARED-DUMP-NEXT: auipc a1, 0
SHARED-DUMP-NEXT: {{l[wd]}} a1, {{-?[0-9]+}}(a1)
