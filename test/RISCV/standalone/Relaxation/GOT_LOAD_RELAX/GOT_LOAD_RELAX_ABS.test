REQUIRES: riscv32 || riscv64
#----------GOT_LOAD_RELAX_ABS.test----------------- Executable------------------#
#BEGIN_COMMENT
# This tests checks GOT load relaxation behavior specific to handling absolute
# symbols.
#END_COMMENT
#START_TEST

RUN: %clang %clangopts -c %p/Inputs/abs.s -o %t.o

## Static executable
RUN: %link %linkopts -static -T %p/Inputs/abs_syms.t --verbose -MapStyle txt -Map %t.static.map \
RUN: %t.o -o %t.static.out 2>&1 | %filecheck %s --check-prefixes=VERBOSE-COMMON,VERBOSE-C
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.static.out | %filecheck %s --check-prefixes=DUMP-COMMON,DUMP-C
RUN: %filecheck %s --input-file=%t.static.map --check-prefix=MAP-C

## Static, pie executable
RUN: %link %linkopts -T %p/Inputs/abs_syms.t -static -pie --verbose -MapStyle txt -Map %t.static-pie.map \
RUN: %t.o -o %t.static-pie.out 2>&1 | %filecheck %s --check-prefixes=VERBOSE-COMMON,VERBOSE-C
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.static-pie.out | %filecheck %s --check-prefixes=DUMP-COMMON,DUMP-C
RUN: %filecheck %s --input-file=%t.static-pie.map --check-prefix=MAP-C

## Static executable with --no-relax-c
RUN: %link %linkopts -T %p/Inputs/abs_syms.t -static --no-relax-c --verbose -MapStyle txt -Map %t.norelaxc.map \
RUN: %t.o -o %t.norelaxc.out 2>&1 | %filecheck %s --check-prefixes=VERBOSE-COMMON,VERBOSE-NO-C
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.norelaxc.out | %filecheck %s --check-prefixes=DUMP-COMMON,DUMP-NO-C
RUN: %filecheck %s --input-file=%t.norelaxc.map --check-prefix=MAP-NO-C

## Shared. The psABI only includes "it’s bound at link time to be within the
## object" as a condition for the relative case, but it is enforced in eld for
## the absolute case as well. Check that no relaxation is performed for
## preemptible absolute symbols.
RUN: %link %linkopts -shared -T %p/Inputs/abs_syms.t \
RUN: --verbose -MapStyle txt -Map %t.shared.map %t.o -o %t.so 2>&1 | %filecheck %s --check-prefix=SHARED-VERBOSE
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.so | %filecheck %s --check-prefix=SHARED-DUMP
RUN: %filecheck %s --input-file=%t.shared.map --check-prefix=MAP-SHARED

RUN: %clang %clangopts -c %p/Inputs/nonsequential.S -o %t.nonseq.o

## Check nonsequential relaxations look as expected when relaxing to c.li
RUN: %link %linkopts -static --defsym var=10 --defsym var2=5 --verbose -MapStyle txt -Map %t.nonseq-cli.map \
RUN: %t.nonseq.o -o %t.nonseq-cli.out 2>&1 | %filecheck %s --check-prefix=VERBOSE-NONSEQ-CLI
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.nonseq-cli.out | %filecheck %s --check-prefixes=DUMP-NONSEQ-COMMON,DUMP-NONSEQ-CLI
RUN: %filecheck %s --input-file=%t.nonseq-cli.map --check-prefix=MAP-NONSEQ-CLI

## Check nonsequential relaxations look as expected when relaxing to addi
RUN: %link %linkopts -static --defsym var=10 --defsym var2=5 --no-relax-c --verbose -MapStyle txt -Map %t.nonseq-addi.map \
RUN: %t.nonseq.o -o %t.nonseq-addi.out 2>&1 | %filecheck %s --check-prefix=VERBOSE-NONSEQ-ADDI
RUN: %objdump --no-print-imm-hex -M no-aliases -d %t.nonseq-addi.out | %filecheck %s --check-prefix=DUMP-NONSEQ-COMMON,DUMP-NONSEQ-ADDI
RUN: %filecheck %s --input-file=%t.nonseq-addi.map --check-prefix=MAP-NONSEQ-ADDI

VERBOSE-COMMON: RISCV_GOT_LOAD : Deleting 4 bytes for symbol 'sym_cli_pos'
VERBOSE-C-NEXT: RISCV_GOT_LOAD : Deleting 2 bytes for symbol 'sym_cli_pos'
VERBOSE-C-NEXT: RISCV_LI_C : relaxing instruction {{.*}} to compressed instruction {{.*}} for symbol sym_cli_pos
