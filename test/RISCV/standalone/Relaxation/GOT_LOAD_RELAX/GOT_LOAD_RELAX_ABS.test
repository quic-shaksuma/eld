DUMP-C: c.li a0, 31
DUMP-NO-C: addi a0, zero, 31
DUMP-C: c.li a1, -32
DUMP-NO-C: addi a1, zero, -32
DUMP-COMMON: addi a2, zero, 32
DUMP-COMMON: addi a3, zero, -33
DUMP-COMMON: addi a0, zero, 2047
DUMP-COMMON: addi a1, zero, -2048
DUMP-COMMON: auipc a2, 0
DUMP-COMMON-NEXT: {{l[wd]}} a2, {{-?[0-9]+}}(a2)
DUMP-COMMON: auipc a3, 0
DUMP-COMMON-NEXT: {{l[wd]}} a3, {{-?[0-9]+}}(a3)
DUMP-COMMON: auipc a0, 0
DUMP-COMMON-NEXT: {{l[wd]}} a0, {{-?[0-9]+}}(a0)
DUMP-COMMON: addi zero, zero, 31
DUMP-COMMON: addi a1, zero, 42

MAP-C: # RelaxationBytesDeleted : 36
