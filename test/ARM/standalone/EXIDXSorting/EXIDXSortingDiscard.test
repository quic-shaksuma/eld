#---EXIDXSortingDiscard.test------------------- Executable,LS ----------------#
#BEGIN_COMMENT
# This tests EXIDX piece sorting when linker script DISCARD rules remove one
# EXIDX input section.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -target arm -c %p/Inputs/exidx.s -o %t1.1.o
RUN: %link -MapStyle txt %linkopts %t1.1.o -T %p/Inputs/script_discard_exidx_f1.t -o %t2.out -Map %t2.map
RUN: %filecheck %s --check-prefix=MAP < %t2.map
RUN: %readelf -u %t2.out | %filecheck %s --check-prefix=UNW

#MAP: # .ARM.exidx.text.f1{{[[:space:]]+}}<GC>
#MAP: .ARM.exidx.text.f2{{[[:space:]]+}}0x11010{{[[:space:]]+}}0x10
#MAP: .ARM.exidx.text.start{{[[:space:]]+}}0x11020{{[[:space:]]+}}0x8
#MAP-NOT: .ARM.exidx.text.f1{{[[:space:]]+}}0x

#UNW: FunctionAddress: 0x11000
#UNW: FunctionAddress: 0x11004
#UNW: FunctionAddress: 0x1100C
#UNW-NOT: FunctionAddress: 0x11008
#END_TEST
